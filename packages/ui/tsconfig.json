{
	"extends": "@component-based-software/config/tsconfig.base.json",

	"compilerOptions": {
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "dist",
		"composite": true,
		"lib": ["DOM", "ES2017"],
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true
	},
	"include": ["src/**/*.d.ts", "src/**/*.ts", "src/**/*.js", "src/**/*.svelte"]
}
